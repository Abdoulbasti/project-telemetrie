# ============================================================
# Projet Télémétrie — variables d'environnement
# 1. Copier ce fichier :        cp .env.example .env
# 2. Générer chaque secret :    openssl rand -hex 32
# ============================================================

# --- Application web (boutique de fleurs) ---
# Mot de passe de la base PostgreSQL dédiée à l'app web
WEBAPP_DB_PASSWORD=change-me
# Secret de signature des cookies de session Express (openssl rand -hex 32)
WEBAPP_SESSION_SECRET=change-me-openssl-rand-hex-32

# --- GlitchTip (suivi des erreurs) ---
# Mot de passe de la base PostgreSQL dédiée à GlitchTip
GLITCHTIP_DB_PASSWORD=change-me
# Clé secrète Django (openssl rand -hex 32)
GLITCHTIP_SECRET_KEY=change-me-openssl-rand-hex-32

# --- Umami (analytics) ---
# Mot de passe de la base PostgreSQL dédiée à Umami
UMAMI_DB_PASSWORD=change-me
# Secret utilisé par Umami pour signer les sessions (openssl rand -hex 32)
UMAMI_APP_SECRET=change-me-openssl-rand-hex-32
